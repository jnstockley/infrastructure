[Unit]
Description=Databasus Verification Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStartPre=/bin/bash -c 'until curl -sf https://databasus.jstockley.com > /dev/null; do sleep 2; done'
ExecStart=/home/jackstockley/verification-agent start
RemainAfterExit=yes
User=jackstockley
Group=jackstockley
WorkingDirectory=/home/jackstockley
Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

[Install]
WantedBy=multi-user.target
